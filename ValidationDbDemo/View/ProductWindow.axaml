<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="320"
        Width="400" Height="320"
        x:Class="ValidationDbDemo.ProductWindow"
        x:CompileBindings="False"
        Title="“овар">
      <StackPanel Margin="15" Spacing="10">

        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Watermark="Ќазвание товара"/>


        <ComboBox ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                  DisplayMemberBinding="{Binding Name}"
                  PlaceholderText="¬ыберите категорию"/>


        <TextBox Text="{Binding PriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Watermark="÷ена"/>
        <WrapPanel>
			<Button Content="—охранить"
                    Command="{Binding SaveCommand}"
                    Margin="0,0,10,10"/>
			<Button Content="ќтмена"

                    Margin="0,0,10,10"/>
        </WrapPanel>
      </StackPanel>
</Window>

